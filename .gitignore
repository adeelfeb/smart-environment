# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts



# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Deployment backups
/root/proof-backups/
proof-backups/

# Webpack cache
.webpack/

# User uploads (runtime files, not source code)
# .gitkeep is preserved so the directory exists in fresh deploys
public/uploads/*
!public/uploads/.gitkeep
public/uploads/complaints/*
!public/uploads/complaints/.gitkeep