MONGODB_URI=mongodb://127.0.0.1:27017/smart-environmental-portal
JWT_SECRET=change_me_to_a_long_random_string
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Auto-seeded Admin User ──────────────────────────────────────────────────
# Created automatically on first startup via scripts/seed-admin.js
# Override defaults in production — never commit real credentials.
SEED_ADMIN_NAME=Super_Admin
SEED_ADMIN_EMAIL=admin@admin.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_ROLE=super_admin

# Email Configuration (choose ONE provider)
# Option 1: Resend (Recommended for development)
# Get API key: https://resend.com/api-keys
# Note: Resend requires domain verification for production, but works with test emails in development
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev  # Use resend.dev domain for testing

# Option 2: SMTP2Go (Alternative)
# Get API key: https://app.smtp2go.com/settings/api
SMTP2GO_API_KEY=
SMTP2GO_FROM_EMAIL=
SMTP2GO_FROM_NAME=

# Option 3: SMTP Protocol (Fallback)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=noreply@designndev.com

# Cloudinary (optional - if not set, uploads save to local filesystem)
# Get keys: https://console.cloudinary.com/app/settings/upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google reCAPTCHA v2 Invisible (protects login, signup, forms from spam/bots)
# Get keys: https://www.google.com/recaptcha/admin
# Add domains: designndev.com, localhost (for local testing)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
