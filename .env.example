MONGODB_URI=mongodb://127.0.0.1:27017/smart-environmental-portal
JWT_SECRET=change_me_to_a_long_random_string
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cloudinary (optional - if not set, uploads save to local filesystem)
# Get keys: https://console.cloudinary.com/app/settings/upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google reCAPTCHA v2 Invisible (protects login, signup, forms from spam/bots)
# Get keys: https://www.google.com/recaptcha/admin
# Add domains: designndev.com, localhost (for local testing)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
